#!/bin/sh
# Version-controlled pre-commit hook for Owl.
# Activate locally with: make install-hooks

set -eu

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED_FILES" ]; then
  echo "No staged files. Skipping pre-commit checks."
  exit 0
fi

GO_STAGED=$(printf '%s\n' "$STAGED_FILES" | grep '\.go$' || true)
RELEVANT_CHANGES=$(printf '%s\n' "$STAGED_FILES" | grep -E '(^|/)\.github/workflows/.*\.ya?ml$|\.go$|^go\.(mod|sum)$|^Makefile$' || true)

if [ -n "$GO_STAGED" ]; then
  echo "Formatting staged Go files..."
  printf '%s\n' "$GO_STAGED" | xargs gofmt -w
  printf '%s\n' "$GO_STAGED" | xargs git add
fi

if [ -z "$RELEVANT_CHANGES" ]; then
  echo "No Go/build/CI changes staged. Skipping Owl quality checks."
  exit 0
fi

echo "Running Owl pre-commit checks..."
make test
make build

echo "Pre-commit checks passed."
